generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   String   @id @default(uuid())
  name                 String
  type                 String // business | ngo
  country              String
  email                String   @unique
  logo_url             String?
  brand_color          String   @default("#6366F1")
  supported_currencies String[] @default(["NGN"])
  status               String   @default("pending") // pending | active | suspended
  webhook_secret       String?
  webhook_url          String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  users            User[]
  apiKeys          ApiKey[]
  customers        Customer[]
  payments         Payment[]
  hostedPages      HostedPage[]
  webhookEndpoints WebhookEndpoint[]
  ledgerEntries    LedgerEntry[]
  receipts         Receipt[]

  @@index([status])
}

model User {
  id            String   @id @default(uuid())
  tenant        Tenant?  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id     String?
  email         String   @unique
  password_hash String
  role          String   @default("admin") // owner | admin | viewer
  verified      Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([tenant_id])
}

model ApiKey {
  id          String   @id @default(uuid())
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id   String
  key_id      String   @unique
  secret_hash String
  mode        String // test | live
  type        String // pk | sk
  prefix      String
  revoked     Boolean  @default(false)
  created_at  DateTime @default(now())

  @@index([tenant_id, revoked])
}

model Customer {
  id         String    @id @default(uuid())
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id  String
  name       String?
  email      String?
  phone      String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  payments   Payment[]

  @@index([tenant_id])
  @@index([email])
}

model Payment {
  id                 String    @id @default(uuid())
  tenant             Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id          String
  customer           Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  customer_id        String?
  amount             Int
  currency           String
  mode               String // payment | donation
  status             String    @default("created") // created | pending | success | failed | cancelled
  idempotency_key    String?
  callback_url       String?
  provider           String    @default("flutterwave")
  provider_reference String?
  provider_response  Json?
  payment_link       String?
  metadata           Json?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  webhookDeliveries WebhookDelivery[]
  receipt           Receipt?
  ledgerEntries     LedgerEntry[]

  @@unique([tenant_id, idempotency_key])
  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
  @@index([provider_reference])
}

model HostedPage {
  id                  String   @id @default(uuid())
  tenant              Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id           String
  name                String
  slug                String   @unique
  fixed_amount        Int?
  allow_custom_amount Boolean  @default(true)
  mode                String // payment | donation
  description         String?
  success_url         String?
  failure_url         String?
  settings            Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([tenant_id])
  @@index([slug])
}

model WebhookEndpoint {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id  String
  url        String
  secret     String
  enabled    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([tenant_id, enabled])
}

model WebhookDelivery {
  id                 String          @id @default(uuid())
  webhookEndpoint    WebhookEndpoint @relation(fields: [webhookEndpoint_id], references: [id], onDelete: Cascade)
  webhookEndpoint_id String
  payment            Payment?        @relation(fields: [payment_id], references: [id], onDelete: SetNull)
  payment_id         String?
  event_type         String // payment.success | payment.failed
  payload            Json
  response_code      Int?
  response_body      String?
  attempts           Int             @default(0)
  last_attempt_at    DateTime?
  next_retry_at      DateTime?
  created_at         DateTime        @default(now())

  @@index([webhookEndpoint_id, created_at])
  @@index([payment_id])
}

model Receipt {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id  String
  payment    Payment  @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  payment_id String   @unique
  sent_to    String
  content    Json
  sent_at    DateTime @default(now())
  created_at DateTime @default(now())

  @@index([tenant_id])
  @@index([payment_id])
}

model LedgerEntry {
  id         String   @id @default(uuid())
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  tenant_id  String
  payment    Payment? @relation(fields: [payment_id], references: [id], onDelete: SetNull)
  payment_id String?
  amount     Int
  currency   String
  direction  String // inbound | outbound | adjustment
  reference  String
  metadata   Json?
  created_at DateTime @default(now())

  @@index([tenant_id, created_at])
  @@index([payment_id])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenant_id  String?
  user_id    String?
  action     String
  detail     Json?
  created_at DateTime @default(now())

  @@index([tenant_id, created_at])
}
